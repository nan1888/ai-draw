{
  "name": "@ai-canvas/canvas-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:service": "tsx src/server.ts",
    "build": "vite build && esbuild src/server.ts --bundle --platform=node --format=esm --target=node20 --banner:js=\"import { createRequire } from 'node:module';const require = createRequire(import.meta.url);\" --external:vite --outfile=dist/server/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@ai-canvas/shared": "workspace:*",
    "@vitejs/plugin-react": "^4.5.0",
    "express": "^4.19.2",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tldraw": "^3.14.0",
    "vite": "^6.0.0",
    "ws": "^8.18.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12"
  }
}
